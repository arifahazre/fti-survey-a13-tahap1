<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Masuk — FTI Survey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Fraunces:ital,wght@0,300;0,700;1,300;1,700&display=swap" rel="stylesheet">
  <style>
    :root {
      --teal-600: #0d9488; --teal-500: #14b8a6; --teal-400: #2dd4bf;
      --amber-400: #fbbf24; --slate-800: #1e293b; --slate-700: #334155;
      --slate-600: #475569; --slate-400: #94a3b8; --slate-300: #cbd5e1;
      --slate-200: #e2e8f0; --slate-100: #f1f5f9; --slate-50: #f8fafc;
      --white: #ffffff; --rose-500: #f43f5e; --rose-50: #fff1f2;
      --emerald-500: #10b981; --emerald-50: #ecfdf5;
      --ff: 'Plus Jakarta Sans', sans-serif;
      --ff-serif: 'Fraunces', serif;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--ff); background: var(--slate-50); color: var(--slate-800); min-height: 100vh; display: flex; }

    /* Panel Kiri */
    .panel-left {
      width: 44%; min-height: 100vh;
      background: linear-gradient(155deg, #0d9488 0%, #0f766e 40%, #115e59 100%);
      position: relative; display: flex; flex-direction: column;
      justify-content: space-between; padding: 48px 52px;
      overflow: hidden; flex-shrink: 0;
    }
    /* Blob animasi */
    .blob { position: absolute; border-radius: 50%; opacity: 0.12; animation: blobMove 8s ease-in-out infinite; }
    .blob-1 { width: 320px; height: 320px; background: #fff; top: -80px; right: -80px; animation-delay: 0s; }
    .blob-2 { width: 200px; height: 200px; background: var(--amber-400); bottom: 120px; right: -40px; animation-delay: 3s; opacity: 0.18; }
    .blob-3 { width: 140px; height: 140px; background: #fff; bottom: -50px; left: 30px; animation-delay: 6s; }
    @keyframes blobMove {
      0%, 100% { transform: translate(0,0) scale(1); }
      33%  { transform: translate(12px,-16px) scale(1.04); }
      66%  { transform: translate(-10px,8px) scale(0.97); }
    }
    /* Dot grid */
    .dot-grid {
      position: absolute; top: 200px; left: 0; width: 100%; height: 180px;
      background-image: radial-gradient(circle, rgba(255,255,255,0.2) 1px, transparent 1px);
      background-size: 22px 22px; pointer-events: none;
    }
    .left-top { position: relative; z-index: 2; }
    /* Logo */
    .logo { display: flex; align-items: center; gap: 12px; margin-bottom: 56px; }
    .logo-icon {
      width: 44px; height: 44px; background: rgba(255,255,255,0.18);
      border: 1.5px solid rgba(255,255,255,0.3); border-radius: 12px;
      display: flex; align-items: center; justify-content: center; backdrop-filter: blur(6px);
    }
    .logo-name { font-family: var(--ff-serif); font-size: 20px; font-weight: 700; color: white; }
    .left-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 16px; }
    .left-heading { font-family: var(--ff-serif); font-size: 34px; font-weight: 700; color: white; line-height: 1.25; margin-bottom: 18px; }
    .left-heading em { font-style: italic; color: var(--amber-400); }
    .left-desc { font-size: 14px; color: rgba(255,255,255,0.72); line-height: 1.75; margin-bottom: 40px; max-width: 300px; }
    /* Pills */
    .feat-list { display: flex; flex-direction: column; gap: 12px; }
    .feat-item {
      display: flex; align-items: center; gap: 12px;
      background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
      border-radius: 12px; padding: 12px 16px; backdrop-filter: blur(4px);
      transition: all 0.2s;
    }
    .feat-item:hover { background: rgba(255,255,255,0.16); transform: translateX(4px); }
    .feat-dot { width: 8px; height: 8px; background: var(--amber-400); border-radius: 50%; flex-shrink: 0; }
    .feat-text { font-size: 13px; color: rgba(255,255,255,0.88); font-weight: 500; }
    .left-bottom { position: relative; z-index: 2; font-size: 11px; color: rgba(255,255,255,0.45); font-weight: 500; }

    /* Panel Kanan */
    .panel-right { flex: 1; display: flex; align-items: center; justify-content: center; padding: 48px 40px; background: var(--white); }
    .form-box { width: 100%; max-width: 400px; }
    .form-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--teal-500); margin-bottom: 10px; }
    .form-title { font-family: var(--ff-serif); font-size: 28px; font-weight: 700; color: var(--slate-800); margin-bottom: 6px; letter-spacing: -0.5px; }
    .form-sub { font-size: 13.5px; color: var(--slate-400); line-height: 1.65; margin-bottom: 28px; }
    /* Divider */
    .divider { display: flex; align-items: center; gap: 14px; margin-bottom: 24px; }
    .divider-line { flex: 1; height: 1px; background: var(--slate-200); }
    .divider-text { font-size: 11.5px; color: var(--slate-400); font-weight: 500; white-space: nowrap; }
    /* Fields */
    .field { margin-bottom: 18px; }
    .field label { display: block; font-size: 12.5px; font-weight: 700; color: var(--slate-700); margin-bottom: 7px; }
    .field input {
      width: 100%; padding: 11px 14px; border: 1.5px solid var(--slate-200);
      border-radius: 10px; font-family: var(--ff); font-size: 14px;
      color: var(--slate-800); background: var(--white); outline: none; transition: all 0.18s;
    }
    .field input:focus { border-color: var(--teal-500); box-shadow: 0 0 0 3px rgba(20,184,166,0.12); }
    .field input::placeholder { color: var(--slate-300); }
    .pwd-wrap { position: relative; }
    .pwd-wrap input { padding-right: 44px; }
    .eye-btn {
      position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
      background: none; border: none; cursor: pointer; color: var(--slate-400);
      display: flex; align-items: center; transition: color 0.15s;
    }
    .eye-btn:hover { color: var(--teal-600); }
    /* Tombol */
    .btn-primary {
      width: 100%; padding: 13px;
      background: linear-gradient(135deg, var(--teal-600), #0f766e);
      border: none; border-radius: 10px; color: white;
      font-family: var(--ff); font-size: 14px; font-weight: 700; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      transition: all 0.2s; box-shadow: 0 4px 14px rgba(13,148,136,0.3);
      position: relative; overflow: hidden;
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(13,148,136,0.4); }
    .btn-primary:active { transform: translateY(0); }
    /* Loading spinner */
    .btn-primary.loading .btn-text { opacity: 0; }
    .btn-primary.loading .btn-spinner { display: block; }
    .btn-spinner { display: none; width: 18px; height: 18px; border: 2.5px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 0.7s linear infinite; position: absolute; }
    @keyframes spin { to { transform: rotate(360deg); } }
    /* Ripple */
    .ripple { position: absolute; border-radius: 50%; background: rgba(255,255,255,0.3); transform: scale(0); animation: ripple-anim 0.55s linear; pointer-events: none; }
    @keyframes ripple-anim { to { transform: scale(4); opacity: 0; } }
    /* Alert */
    .msg-error { background: var(--rose-50); border: 1.5px solid #fecdd3; color: var(--rose-500); border-radius: 10px; padding: 11px 14px; font-size: 13px; font-weight: 600; margin-bottom: 18px; }
    @media (max-width: 820px) { .panel-left { display: none; } .panel-right { padding: 32px 24px; } }
  </style>
</head>
<body>

<!-- Panel Kiri -->
<div class="panel-left">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
  <div class="dot-grid"></div>
  <div class="left-top">
    <div class="logo">
      <div class="logo-icon">
        <!-- Logo clipboard SVG -->
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <rect x="4" y="3" width="14" height="17" rx="2.5" stroke="white" stroke-width="1.5"/>
          <path d="M8 3.5V5.5H14V3.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M8 10h6M8 13.5h4" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <span class="logo-name">FTI Survey</span>
    </div>
    <div class="left-eyebrow">Sistem Survey Mahasiswa</div>
    <div class="left-heading">Suara kamu<br><em>penting</em> bagi kami</div>
    <div class="left-desc">Platform survey digital Fakultas Teknologi Informasi — sampaikan pendapat dan aspirasimu untuk kampus yang lebih baik.</div>
    <div class="feat-list">
      <div class="feat-item"><div class="feat-dot"></div><span class="feat-text">Survey bisa diisi kapan saja, dari mana saja</span></div>
      <div class="feat-item"><div class="feat-dot"></div><span class="feat-text">Jawaban tersimpan aman dan terenkripsi</span></div>
      <div class="feat-item"><div class="feat-dot"></div><span class="feat-text">Notifikasi langsung setelah jawaban terkirim</span></div>
    </div>
  </div>
  <div class="left-bottom">Kelompok A13 · Pemrograman Web · 2026</div>
</div>

<!-- Panel Kanan -->
<div class="panel-right">
  <div class="form-box">
    <div class="form-eyebrow">Selamat Datang</div>
    <div class="form-title">Masuk ke akun</div>
    <div class="form-sub">Gunakan email institusi dan password yang telah diberikan oleh sistem.</div>

    <!-- Pesan error dari server -->
    <% if (pesan) { %>
      <div class="msg-error">
        <% if (pesan === 'empty')     { %>Email dan password tidak boleh kosong.<% } %>
        <% if (pesan === 'notfound')  { %>Email tidak terdaftar di sistem.<% } %>
        <% if (pesan === 'wrongpass') { %>Password salah, coba lagi.<% } %>
        <% if (pesan === 'server')    { %>Terjadi kesalahan server.<% } %>
      </div>
    <% } %>

    <div class="divider">
      <div class="divider-line"></div>
      <span class="divider-text">masuk dengan email institusi</span>
      <div class="divider-line"></div>
    </div>

    <!-- Form login -->
    <form method="POST" action="/login" id="loginForm">
      <div class="field">
        <label for="email">Email Institusi</label>
        <input type="email" id="email" name="email" placeholder="email@unand.ac.id" required autocomplete="off">
      </div>
      <div class="field">
        <label for="password">Kata Sandi</label>
        <div class="pwd-wrap">
          <input type="password" id="password" name="password" placeholder="Masukkan kata sandi" required>
          <button type="button" class="eye-btn" id="eyeToggle">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.4"/>
              <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.4"/>
            </svg>
          </button>
        </div>
      </div>
      <button type="submit" class="btn-primary" id="submitBtn">
        <span class="btn-text">Masuk ke sistem</span>
        <div class="btn-spinner"></div>
      </button>
    </form>

  </div>
</div>

<script>
  // Toggle lihat/sembunyikan password
  document.getElementById('eyeToggle').addEventListener('click', function() {
    const p = document.getElementById('password');
    p.type = p.type === 'password' ? 'text' : 'password';
  });

  // Efek ripple saat tombol diklik
  document.getElementById('submitBtn').addEventListener('click', function(e) {
    const btn = this, rect = btn.getBoundingClientRect();
    const size = Math.max(rect.width, rect.height) * 2;
    const r = document.createElement('span');
    r.className = 'ripple';
    r.style.cssText = `width:${size}px;height:${size}px;left:${e.clientX-rect.left-size/2}px;top:${e.clientY-rect.top-size/2}px`;
    btn.appendChild(r);
    setTimeout(() => r.remove(), 600);
  });

  // Loading state saat form disubmit
  document.getElementById('loginForm').addEventListener('submit', function() {
    const btn = document.getElementById('submitBtn');
    btn.classList.add('loading');
    btn.disabled = true;
  });
</script>
</body>
</html>
